# Environment Configuration File
# ====================================
# This is a sample environment configuration file for this project.
# Copy this file to .env and modify the values according to your environment.
# Do not commit the .env file to version control.
#
# Notes:
# 1. For development, use the default SQLite configuration
# 2. For production, configure MySQL or PostgreSQL variables below
# 3. Database URL will be composed in Django config for clarity and flexibility
# 4. Make sure to use strong passwords and secure keys in production
# 5. Do not commit sensitive information (keys, passwords, etc.) to version control
# 6. It's recommended to use different configuration files for different environments
#    (development, testing, production)

# ============================================================================
# Docker Build Configuration
# ============================================================================
# Control whether to use Chinese mirrors during Docker build
# This variable affects both Debian package sources and PyPI package sources
#
# Values:
#   true  - Use Chinese mirrors (Tsinghua University mirrors)
#          - Debian: mirrors.tuna.tsinghua.edu.cn
#          - PyPI: pypi.tuna.tsinghua.edu.cn
#          - Recommended for development in China (faster build)
#
#   false - Use default sources
#          - Debian: deb.debian.org, security.debian.org
#          - PyPI: pypi.org
#          - Recommended for production builds (GitHub Actions, etc.)
#
# Default values:
#   - Development environment (docker-compose.dev.yml): true
#   - Production environment (docker-compose.yml): false
#   - Can be overridden by setting this variable in .env file
USE_MIRROR=true

# ============================================================================
# Django Configuration
# ============================================================================
SECRET_KEY="kxt=+vy=z4s_c6cy6vnu!v7d4f4y$hx0*!+cm(y^obo^yq0%da"
DJANGO_DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.8.182
CSRF_TRUSTED_ORIGINS='http://localhost,http://192.168.8.182:8000'
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOWED_ORIGINS='http://localhost:3000,http://127.0.0.1:3000,http://192.168.8.182:3000,http://192.168.8.182:8000,https://192.168.8.182:10443'
DJANGO_LOG_LEVEL=INFO
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=adminpassword

# Django Host Port (external port for Django API)
DJANGO_HOST_PORT=8000

# Nginx Port Configuration (external ports for nginx proxy)
# HTTP port for nginx
NGINX_HTTP_PORT=10080
# HTTPS port for nginx
NGINX_HTTPS_PORT=10443

# Attachment URL Configuration
# Base URL for serving email attachments (images, files, etc.)
# Development: http://localhost:8000
# Production: Leave empty to use relative URLs or set to your domain
ATTACHMENT_BASE_URL=http://localhost:8000

# ============================================================================
# Database Configuration
# ============================================================================
# Option 1: SQLite (Recommended for development)
DB_ENGINE=sqlite
SQLITE_PATH=db.sqlite3

# Option 2: MySQL
# Uncomment and configure the following for MySQL
# DB_ENGINE=mysql
# MYSQL_USER=username
# MYSQL_PASSWORD=password
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=db
# MYSQL_ROOT_PASSWORD=rootpassword

# Option 3: PostgreSQL
# Uncomment and configure the following for PostgreSQL
# DB_ENGINE=postgresql
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=yourpassword
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=db

# Advanced: You can also set DATABASE_URL directly (overrides above)
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/db

# ============================================================================
# Celery Configuration
# ============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Celery logging configuration
# Celery system logs (WARNING, INFO, DEBUG)
CELERY_LOG_LEVEL=INFO

# Celery worker configuration
# Number of worker processes
CELERY_CONCURRENCY=1
# Restart worker after N tasks
CELERY_MAX_TASKS_PER_CHILD=1000
# Restart worker after N KB memory usage
CELERY_MAX_MEMORY_PER_CHILD=256000
# Worker prefetch multiplier (tasks to prefetch per worker)
# Single worker with concurrency=1: set to 1
# Multiple workers: set to 2-4 for better task distribution
CELERY_WORKER_PREFETCH_MULTIPLIER=4

# ============================================================================
# Cache Configuration
# ============================================================================
# Cache backend selection: redis, memcached, database, or locmem
# If not specified, will use Redis with database 1 (separate from Celery)
CACHE_BACKEND=redis

# Optional: Custom Redis cache URL (if not specified, will use CELERY_BROKER_URL with database 1)
# CACHE_REDIS_URL=redis://redis:6379/1

# Memcached cache configuration (used when CACHE_BACKEND=memcached)
# CACHE_MEMCACHED_URL=127.0.0.1:11211

# Flower Host Port (external port for Flower monitoring)
FLOWER_HOST_PORT=5555

# ============================================================================
# Haraka Mail Server Configuration
# ============================================================================
# Haraka SMTP port configuration (port 25 for receiving emails)
HARAKA_SMTP_PORT=25

# ============================================================================
# Haraka Email System Configuration
# ============================================================================
# Haraka email base directory (container internal path)
HARAKA_EMAIL_BASE_DIR=/opt/haraka/emails

# Email attachment storage directory (container internal path)
# This is where processed email attachments are permanently stored
EMAIL_ATTACHMENT_DIR=/opt/email_attachments


# ============================================================================
# Threadline Email System Configuration
# ============================================================================
# Auto-assign email domain for virtual mailboxes
AUTO_ASSIGN_EMAIL_DOMAIN=devify.local

# Default language for new users
DEFAULT_LANGUAGE=en-US

# Default scene for new users (chat or product_issue)
DEFAULT_SCENE=chat

# Threadline configuration file path (container internal path)
THREADLINE_CONFIG_PATH=/opt/devify/conf/threadline

# ============================================================================
# Accounts & Authentication Configuration
# ============================================================================
# This section contains all settings related to user accounts, authentication,
# registration, and email notifications

# ----------------
# Email Configuration (for registration and notification emails)
# ----------------
# Email backend: smtp (production), console (development - prints to terminal)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP server settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@devify.local

# ----------------
# Google OAuth Configuration
# ----------------
# Important: In Google Cloud Console, set the redirect URI to:
# http://localhost:8000/accounts/google/login/callback/
# NOT the frontend URL!
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret

# ----------------
# WeChat Authentication (Legacy, optional)
# ----------------
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ----------------
# User Registration Configuration
# ----------------
# Note: Virtual email domain is configured via AUTO_ASSIGN_EMAIL_DOMAIN above
# Registration token expiry time in hours
REGISTRATION_TOKEN_EXPIRY_HOURS=24

# Frontend URL (used for OAuth redirects and email links)
# This is where Django will redirect users after OAuth login
FRONTEND_URL=http://localhost:3000

# ============================================================================
# (Devtoolbox) Azure OpenAI LLM Configuration
# ============================================================================
# Azure OpenAI endpoint URL
# AZURE_OPENAI_API_BASE=https://your-openai-endpoint.openai.azure.com/
# Azure OpenAI API key
# AZURE_OPENAI_API_KEY=your-azure-openai-api-key
# Azure OpenAI deployment name (model name)
# AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
# Azure OpenAI API version
# AZURE_OPENAI_API_VERSION=2024-10-01-preview
# Maximum number of tokens to generate in the response (default: 10000)
# AZURE_OPENAI_MAX_TOKENS=10000
# Temperature for response randomness, 0.0-2.0 (default: 0.3)
# Lower values = more focused/deterministic, Higher values = more creative/random
# AZURE_OPENAI_TEMPERATURE=0.3

# LLM output language (e.g., English, Chinese, Japanese)
# LLM_OUTPUT_LANGUAGE=English

# ============================================================================
# Azure OCR (Document Intelligence) Configuration
# ============================================================================
# AZURE_DOCUMENT_INTELLIGENCE_KEY=your-azure-document-intelligence-key
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-ocr-endpoint.cognitiveservices.azure.com/

# ============================================================================
# Proxy Configuration
# ============================================================================
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080