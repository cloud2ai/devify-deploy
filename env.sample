# ============================================================================
# Devify - Production Deployment Configuration
# ============================================================================
# This is the production deployment configuration for SaaS version
#
# Differences from open source edition:
# - Uses remote Docker images from Aliyun registry
# - Includes Haraka for real-time email processing
# - Commercial features enabled (billing, payment)
# - Production-grade security settings
# ============================================================================

# ============================================================================
# ⚠️  IMPORTANT: Boolean Value Convention
# ============================================================================
# All boolean environment variables MUST use lowercase "true" or "false"
#
# ✅ Correct:   DJANGO_DEBUG=true, BILLING_ENABLED=false
# ❌ Incorrect: DJANGO_DEBUG=true, BILLING_ENABLED=1
#
# Reason: Ensures consistent behavior across Shell scripts and Python code.
# Only "true" and "false" (lowercase) are accepted as valid boolean values.
# ============================================================================

# ============================================================================
# Docker Build Configuration
# ============================================================================
APT_MIRROR_URL=https://archive.ubuntu.com/ubuntu
PIP_INDEX_URL=https://pypi.org/simple
PIP_TRUSTED_HOST=pypi.org

# ============================================================================
# Django Configuration
# ============================================================================
SECRET_KEY="change-this-to-a-random-secret-key-in-production"
DJANGO_DEBUG=false
ALLOWED_HOSTS=app.aimychats.com,aimychats.com
CSRF_TRUSTED_ORIGINS='https://app.aimychats.com,https://aimychats.com'
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOWED_ORIGINS='https://app.aimychats.com'
DJANGO_LOG_LEVEL=INFO
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@aimychats.com
DJANGO_SUPERUSER_PASSWORD=change-this-password

# Nginx Port Configuration (internal, proxied by Nginx Proxy Manager)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
# Admin management port (should be restricted by security group)
NGINX_ADMIN_PORT=19443

# Attachment URL Configuration
ATTACHMENT_BASE_URL=https://app.aimychats.com

# ============================================================================
# Database Configuration (Production)
# ============================================================================
DB_ENGINE=mysql
MYSQL_USER=devify
MYSQL_PASSWORD=change-this-password
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=devify
MYSQL_ROOT_PASSWORD=change-this-root-password

# ============================================================================
# Celery Configuration
# ============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_LOG_LEVEL=INFO
CELERY_CONCURRENCY=4
CELERY_MAX_TASKS_PER_CHILD=1000
CELERY_MAX_MEMORY_PER_CHILD=256000
CELERY_WORKER_PREFETCH_MULTIPLIER=4

# ============================================================================
# Cache Configuration
# ============================================================================
CACHE_BACKEND=redis

# ============================================================================
# Email System Configuration
# ============================================================================
# Email attachment storage directory (container internal path)
EMAIL_ATTACHMENT_DIR=/opt/email_attachments

# Haraka email configuration (SaaS version with real-time SMTP)
AUTO_ASSIGN_EMAIL_DOMAIN=aimychats.com
HARAKA_EMAIL_BASE_DIR=/opt/haraka/emails
HARAKA_SMTP_PORT=25

# Default language for new users
DEFAULT_LANGUAGE=en-US

# Default scene for new users
DEFAULT_SCENE=chat

# Threadline configuration file path
THREADLINE_CONFIG_PATH=/opt/devify/conf/threadline

# ============================================================================
# Billing Configuration (Production SaaS)
# ============================================================================
# Production SaaS: Enable billing with actual costs
BILLING_ENABLED=true
CREDITS_CHECK_ENABLED=true
DEFAULT_FREE_CREDITS=10
WORKFLOW_COST_CREDITS=1

# Cost tracking for analytics
ENABLE_COST_TRACKING=true
AUTO_REFUND_SYSTEM_ERRORS=true

# Stripe payment integration (required for production)
STRIPE_LIVE_SECRET_KEY=sk_live_your_key_here
STRIPE_TEST_SECRET_KEY=sk_test_your_key_here
STRIPE_LIVE_MODE=false
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# ============================================================================
# Accounts & Authentication Configuration
# ============================================================================
# Email backend for notifications
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# SMTP server settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@aimychats.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@aimychats.com

# Django Site Configuration (Required for OAuth)
# The domain where your application is hosted
# Development: localhost:8000 or 127.0.0.1:8000
# Production: yourdomain.com or your-ip:port
SITE_DOMAIN=app.aimychats.com
SITE_NAME=AImyChats

# Google OAuth Configuration
# Redirect URI: https://app.aimychats.com/accounts/google/login/callback/
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret

# OAuth Protocol Configuration
# CRITICAL: Set to 'https' in production to ensure OAuth callback URLs use HTTPS
# This fixes the redirect_uri_mismatch error when using reverse proxies
ACCOUNT_DEFAULT_HTTP_PROTOCOL=https

# Registration token expiry
REGISTRATION_TOKEN_EXPIRY_HOURS=24

# Frontend URL (for OAuth redirects and email links)
FRONTEND_URL=https://app.aimychats.com

# Frontend API Base URL (for CORS and OAuth redirects)
# Should match the backend URL accessible from the frontend
VITE_API_BASE_URL=https://app.aimychats.com

# ============================================================================
# AI Services Configuration
# ============================================================================
# Azure OpenAI Configuration
AZURE_OPENAI_API_BASE=https://your-openai-endpoint.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-01-preview
AZURE_OPENAI_MAX_TOKENS=10000
AZURE_OPENAI_TEMPERATURE=0.3

# LLM output language
LLM_OUTPUT_LANGUAGE=English

# Azure OCR (Document Intelligence) Configuration
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-azure-document-intelligence-key
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-ocr-endpoint.cognitiveservices.azure.com/

# ============================================================================
# Proxy Configuration (Optional)
# ============================================================================
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
